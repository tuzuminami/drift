{
  "name": "@tuzuminami/drift",
  "version": "1.0.0",
  "description": "Scenario and context orchestration primitives for deterministic conversational systems.",
  "type": "module",
  "license": "Apache-2.0",
  "private": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    },
    "./migrations": {
      "types": "./dist/src/postgres.d.ts",
      "import": "./dist/src/postgres.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "drift": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "migrations",
    "openapi",
    "schemas",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "db:migrate": "npm run build && node dist/src/postgres.js migrate",
    "test": "node --test dist/**/*.test.js",
    "check": "npm run build && npm run test && npm run check:contracts && npm run check:version && npm run check:migrations && npm run check:licenses && npm run check:private-boundary && npm run check:package-boundary && npm run check:consumer-package",
    "check:contracts": "node scripts/check-public-contracts.mjs && node scripts/check-aster-producer-contract.mjs",
    "check:version": "node scripts/check-version-metadata.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "check:licenses": "node scripts/check-dependency-licenses.mjs",
    "check:private-boundary": "node scripts/check-private-boundary.mjs",
    "check:package-boundary": "node scripts/check-package-boundary.mjs",
    "check:consumer-package": "node scripts/check-consumer-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
