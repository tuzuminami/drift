{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuzuminami.github.io/drift/schemas/context-pack.schema.json",
  "title": "ContextPack",
  "type": "object",
  "required": [
    "sessionId",
    "scenarioId",
    "scenarioVersion",
    "sceneId",
    "instructions",
    "slots",
    "policyReferences",
    "artifactReferences",
    "provenance"
  ],
  "additionalProperties": false,
  "properties": {
    "sessionId": { "type": "string" },
    "scenarioId": { "type": "string" },
    "scenarioVersion": { "type": "string" },
    "sceneId": { "type": "string" },
    "instructions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "slots": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "policyReferences": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifactReferences": {
      "type": "array",
      "items": { "$ref": "#/$defs/compiledArtifactReference" }
    },
    "provenance": {
      "type": "object",
      "required": ["sequence", "correlationId"],
      "additionalProperties": false,
      "properties": {
        "sequence": { "type": "integer", "minimum": 0 },
        "correlationId": { "type": "string" }
      }
    }
  },
  "$defs": {
    "compiledArtifactReference": {
      "type": "object",
      "required": ["artifactId", "artifactVersion", "producer", "schemaVersion", "compilerVersion", "digestAlgorithm", "contentHash"],
      "additionalProperties": false,
      "properties": {
        "artifactId": { "type": "string", "minLength": 1 },
        "artifactVersion": { "type": "string", "minLength": 1 },
        "producer": { "const": "aster" },
        "schemaVersion": { "const": "aster.drift-reference/1" },
        "compilerVersion": { "type": "string", "minLength": 1 },
        "digestAlgorithm": { "const": "sha256" },
        "contentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    }
  }
}
