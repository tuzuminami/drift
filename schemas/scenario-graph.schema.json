{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tuzuminami.github.io/drift/schemas/scenario-graph.schema.json",
  "title": "ScenarioGraph",
  "type": "object",
  "required": ["scenarioId", "version", "scenes", "transitions"],
  "additionalProperties": false,
  "properties": {
    "scenarioId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "kind", "context"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["start", "normal", "terminal"] },
        "context": {
          "type": "object",
          "required": ["instructions", "requiredSlots", "policyReferences"],
          "additionalProperties": false,
          "properties": {
            "instructions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requiredSlots": {
              "type": "array",
              "items": { "type": "string" }
            },
            "policyReferences": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "transition": {
      "type": "object",
      "required": ["id", "from", "to", "eventType"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "eventType": { "type": "string", "minLength": 1 },
        "guard": {
          "type": "object",
          "required": ["slotEquals", "reasonCode"],
          "additionalProperties": false,
          "properties": {
            "slotEquals": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "reasonCode": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
